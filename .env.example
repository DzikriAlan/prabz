# Database (PostgreSQL / Supabase)
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# JWT (must match the token issuer's secret)
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_NAME="prabz"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Payment gateway (Mayar) — leave unset to auto-mark orders PAID (dev fallback)
# MAYAR_API_KEY=
# MAYAR_BASE_URL="https://api.mayar.id/hl/v1"
# MAYAR_REDIRECT_URL="http://localhost:3000/commerce"
